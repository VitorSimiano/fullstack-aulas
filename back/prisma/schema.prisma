datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  authorId    Int
  author      User    @relation(fields: [authorId], references: [id])
  tags        Tag[]
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String
  tasks Task[]
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  tasks Task[]
}

model Message {
  id        Int      @id @default(autoincrement())
  username  String
  text      String
  createdAt DateTime @default(now())
}